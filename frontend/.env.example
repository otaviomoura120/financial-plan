NUXT_PUBLIC_API_BASE_URL=
NUXT_APP_BASE_URL=http://localhost:3000
MAPBOX_ACCESS_TOKEN=
VITE_API_BASE_URL=

# Auth0 — use "Regular Web Application" type in the Auth0 Dashboard
